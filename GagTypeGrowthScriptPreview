requestPlantSeedRemote.OnServerEvent:Connect(function(player: Player, payload)
	local position = payload and payload.position
	if typeof(position) ~= "Vector3" then
		return
	end

	local requestedName = readRequestedSeedName(payload)

	local playerPlot = getPlayerPlot(player)
	if GrowthConfig.RequireOwnedPlot and (not playerPlot or not isPointInsidePlot(playerPlot, position)) then
		return
	end

	local plantingTool, modelName, rewardToolName = resolvePlantingTool(player, requestedName)
	if not plantingTool or not modelName then
		return
	end

	local template = modelStorageFolder:FindFirstChild(modelName)
	if not template or not template:IsA("Model") then
		return
	end

	local startScale, finalScale, growTime = getSettingsForModelName(modelName)

	local clone = template:Clone()
	setModelAnchored(clone, true)

	clone:SetAttribute("CanHarvest", true)
	clone:SetAttribute("Harvested", false)
	clone:SetAttribute("OwnerUserId", player.UserId)
	clone:SetAttribute("RewardToolName", rewardToolName or modelName)
	clone:SetAttribute("StartScale", startScale)
	clone:SetAttribute("FinalScale", finalScale)
	clone:SetAttribute("GrowTime", growTime)

	local lookDirection = getCharacterHorizontalLook(player.Character)

	local _, modelSize = clone:GetBoundingBox()
	local plantedPosition = Vector3.new(position.X, position.Y + (modelSize.Y * 0.5), position.Z)
	clone:PivotTo(CFrame.lookAt(plantedPosition, plantedPosition + lookDirection))
	clone.Parent = growablesFolder

	consumeOneSeedFromTool(player, plantingTool)
end)

spawnRequestRemote.OnServerEvent:Connect(function(player: Player)
	local cooldown = readNumberFromTable(GrowthConfig, "TestSpawnCooldown", 0.25)
	local now = os.clock()
	local lastRequest = lastSpawnRequestAt[player.UserId] or 0

	if now - lastRequest < cooldown then
		return
	end

	lastSpawnRequestAt[player.UserId] = now
	local testActionMode = GrowthConfig.TestActionMode
	if testActionMode == "SpawnGrowable" then
		spawnTestGrowable(player)
		return
	end

	giveRandomSeed(player)
end)

Players.PlayerRemoving:Connect(function(player)
	lastSpawnRequestAt[player.UserId] = nil
end)

while true do
	local now = os.clock()

	for model, state in pairs(activeGrowth) do
		if not model.Parent then
			activeGrowth[model] = nil
			continue
		end

		local age = now - state.startedAt
		local alpha = math.clamp(age / state.growTime, 0, 1)
		local currentScale = state.startScale + ((state.finalScale - state.startScale) * alpha)
		local growthPercent = alpha * 100

		model:ScaleTo(currentScale)
		keepModelBottomAt(model, state.groundY)
		model:SetAttribute("CurrentAge", math.min(age, state.growTime))
		model:SetAttribute("GrowthPercent", growthPercent)

		if alpha >= 1 then
			model:SetAttribute("CurrentAge", state.growTime)
			model:SetAttribute("GrowthPercent", 100)
			model:SetAttribute("IsMature", true)
			model:SetAttribute("GrowthState", "Mature")
			activeGrowth[model] = nil
		end
	end

	task.wait(GrowthConfig.UpdateInterval or 0.05)
end
