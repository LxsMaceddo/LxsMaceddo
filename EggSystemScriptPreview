local function compactTemplateSlots(
	eggToolTip: GuiObject?,
	slots: {PreviewSlotBinding},
	billboardWidth: number,
	billboardHeight: number
)
	if #slots <= 0 then
		return
	end

	local slotCount = #slots
	local paddingPx = math.max(0, math.floor(getPreviewStyleSettingNumber("PreviewSlotPadding", math.clamp(math.floor(billboardWidth * 0.014), 2, 8))))
	local usableWidth = math.max(92, billboardWidth - 14)
	local slotWidth = math.floor((usableWidth - ((slotCount - 1) * paddingPx)) / slotCount)
	local slotMinWidth = math.max(24, math.floor(getPreviewStyleSettingNumber("PreviewSlotMinWidth", 64)))
	local slotMaxWidth = math.max(slotMinWidth, math.floor(getPreviewStyleSettingNumber("PreviewSlotMaxWidth", 120)))
	slotWidth = math.clamp(slotWidth, slotMinWidth, slotMaxWidth)
	local slotHeightScale = math.clamp(getPreviewStyleSettingNumber("PreviewSlotHeightScale", 1.18), 0.7, 2.0)
	local slotHeight = math.max(20, math.floor(slotWidth * slotHeightScale))
	local chanceHeightCfg = math.clamp(math.floor(getPreviewStyleSettingNumber("PreviewSlotChanceHeight", 14)), 0, 40)
	local petChanceGap = getPetRarityChanceGap()

	if eggToolTip then
		normalizeToolTipLayouts(eggToolTip)
		eggToolTip.AnchorPoint = Vector2.new(0, 0)
		eggToolTip.Position = UDim2.fromScale(0, 0)
		eggToolTip.Size = UDim2.new(1, -4, 1, -2)
		eggToolTip.BackgroundTransparency = 1
		eggToolTip.ClipsDescendants = true
	end

	local totalWidth = slotCount * slotWidth + ((slotCount - 1) * paddingPx)
	local startXOffset = getPreviewStyleSettingNumber("PreviewSlotStartXOffset", 0)
	local startYOffset = getPreviewStyleSettingNumber("PreviewSlotStartYOffset", 0)
	local startX = math.max(0, math.floor((billboardWidth - totalWidth) * 0.5 + startXOffset))
	local startY = math.max(0, math.floor((billboardHeight - slotHeight) * 0.5 + startYOffset))

	for i, slot in ipairs(slots) do
		removeSizingConstraints(slot.Root)
		removeSizingConstraints(slot.Icon)
		normalizeAutoSize(slot.Root)
		normalizeAutoSize(slot.Icon)
		local reserveChanceSpace = shouldReserveChanceSpace(slot.Root)
		local iconScaleCfg = getSlotIconScale(slot.Root)
		local iconOffsetYCfg = getSlotIconOffsetY(slot.Root)
		slot.Root.LayoutOrder = i
		slot.Root.ClipsDescendants = reserveChanceSpace
		if eggToolTip and slot.Root.Parent == eggToolTip then
			slot.Root.AnchorPoint = Vector2.new(0, 0)
			slot.Root.Position = UDim2.fromOffset(startX + ((i - 1) * (slotWidth + paddingPx)), startY)
		end
		slot.Root.Size = UDim2.fromOffset(slotWidth, slotHeight)

		if slot.Root:IsA("ImageLabel") or slot.Root:IsA("ImageButton") then
			slot.Root.ScaleType = Enum.ScaleType.Fit
		end
		if slot.Icon ~= slot.Root then
			slot.Icon.AnchorPoint = Vector2.new(0.5, 0.5)
			local chanceShift = 0
			if reserveChanceSpace and chanceHeightCfg > 0 then
				chanceShift = (chanceHeightCfg / math.max(1, slotHeight)) * 0.45
			end
			slot.Icon.Position = UDim2.fromScale(0.5, 0.5 - chanceShift + iconOffsetYCfg)
			slot.Icon.Size = UDim2.fromScale(iconScaleCfg, iconScaleCfg)
		end
		if slot.Icon:IsA("ImageLabel") or slot.Icon:IsA("ImageButton") then
			slot.Icon.ScaleType = Enum.ScaleType.Fit
		end

		if slot.ChanceLabel then
			normalizeAutoSize(slot.ChanceLabel)
			if reserveChanceSpace then
				slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 1)
				slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, 0)
			else
				slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 0)
				slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, petChanceGap)
			end
			slot.ChanceLabel.Size = UDim2.new(1, 0, 0, chanceHeightCfg)
			if slot.ChanceLabel:IsA("TextLabel") or slot.ChanceLabel:IsA("TextButton") or slot.ChanceLabel:IsA("TextBox") then
				slot.ChanceLabel.TextScaled = false
				slot.ChanceLabel.TextSize = math.clamp(math.floor(slotWidth * 0.3), 10, 13)
			end
		end
	end
end

local function getSlotSortIndex(slotRoot: GuiObject, fallbackIndex: number): number
	local attr = slotRoot:GetAttribute("EggSlotIndex")
	if typeof(attr) == "number" then
		return math.max(1, math.floor(attr))
	end
	local suffix = string.match(slotRoot.Name, "(%d+)$")
	if suffix then
		local n = tonumber(suffix)
		if n then
			return math.max(1, math.floor(n))
		end
	end
	return fallbackIndex
end

local function buildSlotBinding(slotRoot: GuiObject, fallbackIndex: number): PreviewSlotBinding?
	local icon: GuiObject? = nil
	if slotRoot:IsA("ImageLabel") or slotRoot:IsA("ImageButton") then
		if shouldUseImageSlotAsContainer(slotRoot) then
			icon = ensureSlotOverlayIcon(slotRoot)
		else
			icon = slotRoot
		end
	else
		local iconNamed = slotRoot:FindFirstChild("Icon", true)
		if iconNamed and (iconNamed:IsA("ImageLabel") or iconNamed:IsA("ImageButton")) then
			icon = iconNamed :: GuiObject
		else
			for _, d in ipairs(slotRoot:GetDescendants()) do
				if d:IsA("ImageLabel") or d:IsA("ImageButton") then
					icon = d :: GuiObject
					break
				end
			end
		end
	end
	if not icon then
		-- Fallback automatico para templates onde o slot e somente Frame.
		local autoIcon = Instance.new("ImageLabel")
		autoIcon.Name = "AutoIcon"
		autoIcon.AnchorPoint = Vector2.new(0.5, 0.5)
		autoIcon.Position = UDim2.fromScale(0.5, 0.5)
		autoIcon.Size = UDim2.fromScale(0.84, 0.84)
		autoIcon.BackgroundTransparency = 1
		autoIcon.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
		autoIcon.ScaleType = Enum.ScaleType.Fit
		autoIcon.Parent = slotRoot
		icon = autoIcon
	end

	local chanceAny = slotRoot:FindFirstChild("Chance", true)
	if not chanceAny then
		chanceAny = slotRoot:FindFirstChild("Percent", true)
	end

	local chanceLabel: GuiObject? = nil
	if chanceAny and (chanceAny:IsA("TextLabel") or chanceAny:IsA("TextButton") or chanceAny:IsA("TextBox")) then
		chanceLabel = chanceAny
	end

	return {
		SortIndex = getSlotSortIndex(slotRoot, fallbackIndex),
		Root = slotRoot,
		Icon = icon,
		ChanceLabel = chanceLabel,
	}
end

local function getTemplateSource(): Instance?
	local settings = EggCatalog.Settings or {}
	local configured = tostring(settings.PreviewTemplateName or "EggPreviewTemplate")
	local names = {
		configured,
		"EggPreviewTemplate",
		"EggPreviewBillboardTemplate",
		"EggPreviewGuiTemplate",
	}
	for _, name in ipairs(names) do
		local found = ReplicatedStorage:FindFirstChild(name, true)
		if found then
			return found
		end
	end
	return nil
end

