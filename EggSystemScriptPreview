local function normalizeTemplateRootLayout(billboard: BillboardGui): GuiObject?
	local rootAny = billboard:FindFirstChild("Root")
	if not rootAny then
		rootAny = billboard:FindFirstChild("Frame")
	end
	if rootAny and rootAny:IsA("GuiObject") then
		rootAny.AnchorPoint = Vector2.new(0, 0)
		rootAny.Position = UDim2.fromScale(0, 0)
		rootAny.Size = UDim2.fromScale(1, 1)
		rootAny.ClipsDescendants = false
		return rootAny
	end
	return nil
end

local function ensureNamedUiScale(guiObj: GuiObject, name: string): UIScale
	local existing = guiObj:FindFirstChild(name)
	if existing and existing:IsA("UIScale") then
		return existing
	end
	if existing then
		existing:Destroy()
	end
	local scale = Instance.new("UIScale")
	scale.Name = name
	scale.Scale = 1
	scale.Parent = guiObj
	return scale
end

local function applyTemplateAutoScale(
	root: GuiObject?,
	baseWidth: number,
	baseHeight: number,
	targetWidth: number,
	targetHeight: number,
	keepTemplateSize: boolean
)
	if not root then
		return
	end
	local autoScale = ensureNamedUiScale(root, "EggTemplateAutoScale")
	if keepTemplateSize then
		autoScale.Scale = 1
		return
	end
	local sx = (baseWidth > 0) and (targetWidth / baseWidth) or 1
	local sy = (baseHeight > 0) and (targetHeight / baseHeight) or 1
	autoScale.Scale = math.clamp(math.min(sx, sy), 0.2, 4)
end

local function normalizeTemplateSlotVisuals(slots: {PreviewSlotBinding})
	local chanceHeightCfg = math.clamp(math.floor(getPreviewStyleSettingNumber("PreviewSlotChanceHeight", 14)), 0, 40)
	local petChanceGap = getPetRarityChanceGap()

	for _, slot in ipairs(slots) do
		local reserveChanceSpace = shouldReserveChanceSpace(slot.Root)
		local iconScaleCfg = getSlotIconScale(slot.Root)
		local iconOffsetYCfg = getSlotIconOffsetY(slot.Root)

		slot.Root.ClipsDescendants = reserveChanceSpace
		if slot.Root:IsA("ImageLabel") or slot.Root:IsA("ImageButton") then
			slot.Root.ScaleType = Enum.ScaleType.Fit
		end

		if slot.Root ~= slot.Icon and slot.Icon.Parent == slot.Root then
			local chanceHeight = 0
			if slot.ChanceLabel and slot.ChanceLabel.Parent == slot.Root then
				chanceHeight = chanceHeightCfg
				if reserveChanceSpace then
					slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 1)
					slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, 0)
				else
					slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 0)
					slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, petChanceGap)
				end
				slot.ChanceLabel.Size = UDim2.new(1, 0, 0, chanceHeight)
				slot.ChanceLabel.ZIndex = math.max(slot.ChanceLabel.ZIndex, slot.Root.ZIndex + 1)
			end

			slot.Icon.AnchorPoint = Vector2.new(0.5, 0.5)
			local chanceShift = 0
			if reserveChanceSpace and chanceHeight > 0 then
				chanceShift = chanceHeight / math.max(1, slot.Root.AbsoluteSize.Y) * 0.45
			end
			slot.Icon.Position = UDim2.fromScale(0.5, 0.5 - chanceShift + iconOffsetYCfg)
			slot.Icon.Size = UDim2.fromScale(iconScaleCfg, iconScaleCfg)
		elseif slot.ChanceLabel then
			if reserveChanceSpace then
				slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 1)
				slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, 0)
			else
				slot.ChanceLabel.AnchorPoint = Vector2.new(0.5, 0)
				slot.ChanceLabel.Position = UDim2.new(0.5, 0, 1, petChanceGap)
			end
			slot.ChanceLabel.Size = UDim2.new(1, 0, 0, chanceHeightCfg)
			slot.ChanceLabel.ZIndex = math.max(slot.ChanceLabel.ZIndex, slot.Root.ZIndex + 1)
		end
	end
end

