local function getPreviewStyleSettingNumber(key: string, fallback: number): number
	local settings = EggCatalog.Settings or {}
	return tonumber(settings[key]) or fallback
end

local function getPreviewStyleSettingBool(key: string, fallback: boolean): boolean
	local settings = EggCatalog.Settings or {}
	local raw = settings[key]
	if typeof(raw) == "boolean" then
		return raw
	end
	return fallback
end

local function isPetRaritySlotRoot(slotRoot: GuiObject): boolean
	if string.match(slotRoot.Name, "^PetRarity%d+$") then
		return true
	end
	return slotRoot:GetAttribute("EggPetRaritySlot") == true
end

local function getSlotIconScale(slotRoot: GuiObject): number
	local base = getPreviewStyleSettingNumber("PreviewSlotIconScale", 0.9)
	if isPetRaritySlotRoot(slotRoot) then
		base = getPreviewStyleSettingNumber("PreviewPetRarityIconScale", base)
	end
	return math.clamp(base, 0.2, 1.4)
end

local function getSlotIconOffsetY(slotRoot: GuiObject): number
	if isPetRaritySlotRoot(slotRoot) then
		return getPreviewStyleSettingNumber("PreviewPetRarityIconOffsetY", 0)
	end
	return getPreviewStyleSettingNumber("PreviewSlotIconOffsetY", -0.03)
end

local function shouldReserveChanceSpace(slotRoot: GuiObject): boolean
	if isPetRaritySlotRoot(slotRoot) then
		return getPreviewStyleSettingBool("PreviewPetRarityReserveChanceSpace", false)
	end
	return true
end

local function getPetRarityChanceGap(): number
	return getPreviewStyleSettingNumber("PreviewPetRarityChanceGap", 0)
end

local function shouldUseImageSlotAsContainer(slotRoot: GuiObject): boolean
	local settings = EggCatalog.Settings or {}
	if settings.PreviewImageSlotAsContainer == false then
		return false
	end
	local explicit = slotRoot:GetAttribute("EggSlotImageAsContainer")
	if typeof(explicit) == "boolean" then
		return explicit
	end
	if isPetRaritySlotRoot(slotRoot) then
		return true
	end
	if slotRoot:FindFirstChild("Chance", true) or slotRoot:FindFirstChild("Percent", true) then
		return true
	end
	return false
end

local function ensureSlotOverlayIcon(slotRoot: GuiObject): GuiObject
	local existing = slotRoot:FindFirstChild("Icon", true)
	if existing and (existing:IsA("ImageLabel") or existing:IsA("ImageButton")) then
		return existing :: GuiObject
	end
	local overlay = Instance.new("ImageLabel")
	overlay.Name = "Icon"
	overlay.BackgroundTransparency = 1
	overlay.AnchorPoint = Vector2.new(0.5, 0.5)
	overlay.Position = UDim2.fromScale(0.5, 0.5 + getSlotIconOffsetY(slotRoot))
	local iconScale = getSlotIconScale(slotRoot)
	overlay.Size = UDim2.fromScale(iconScale, iconScale)
	overlay.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
	overlay.ScaleType = Enum.ScaleType.Fit
	overlay.ZIndex = slotRoot.ZIndex + 1
	overlay.Parent = slotRoot
	return overlay
end

local function getConfiguredBillboardSize(): (number, number)
