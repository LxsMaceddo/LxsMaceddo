local function createTemplateBillboardBinding(source: Instance): PromptPreviewBinding?
	local settings = EggCatalog.Settings or {}
	local offsetY = tonumber(settings.PreviewBillboardOffsetY) or 3.7
	local keepTemplateSize = settings.PreviewKeepTemplateSize == true
	local forceCompactSlots = settings.PreviewForceCompactSlots == true
	local width, height = getConfiguredBillboardSize()
	local baseWidth = width
	local baseHeight = height

	local billboard: BillboardGui? = nil
	if source:IsA("BillboardGui") then
		local sx = source.Size.X.Offset
		local sy = source.Size.Y.Offset
		baseWidth = math.max(1, math.floor(sx > 0 and sx or width))
		baseHeight = math.max(1, math.floor(sy > 0 and sy or height))
		billboard = source:Clone()
		if not keepTemplateSize then
			billboard.Size = UDim2.fromOffset(width, height)
		end
	elseif source:IsA("GuiObject") then
		local wrapper = Instance.new("BillboardGui")
		wrapper.Name = "EggPreviewBillboard"
		local sx = source.Size.X.Offset
		local sy = source.Size.Y.Offset
		baseWidth = math.max(1, math.floor(sx > 0 and sx or width))
		baseHeight = math.max(1, math.floor(sy > 0 and sy or height))
		if keepTemplateSize then
			if sx <= 0 then
				sx = width
			end
			if sy <= 0 then
				sy = height
			end
			wrapper.Size = UDim2.fromOffset(sx, sy)
		else
			wrapper.Size = UDim2.fromOffset(width, height)
		end
		wrapper.AlwaysOnTop = true
		wrapper.LightInfluence = 0
		wrapper.MaxDistance = 80
		wrapper.StudsOffsetWorldSpace = Vector3.new(0, offsetY, 0)
		local root = source:Clone()
		root.Name = "Root"
		root.AnchorPoint = Vector2.new(0, 0)
		root.Position = UDim2.fromScale(0, 0)
		if root.Size.X.Scale == 0 and root.Size.X.Offset == 0 and root.Size.Y.Scale == 0 and root.Size.Y.Offset == 0 then
			root.Size = UDim2.fromScale(1, 1)
		end
		root.Parent = wrapper
		billboard = wrapper
	end
	if not billboard then
		return nil
	end

	billboard.Enabled = false
	billboard.Parent = gui
	local root = normalizeTemplateRootLayout(billboard)

	local title = findFirstTextLabelByNames(billboard, {"Title", "EggName", "Name"})
	local price = findFirstTextLabelByNames(billboard, {"Price", "Cost", "Value"})

	local slotCandidates: {GuiObject} = {}
	local detectedPetRaritySlots = false
	local eggToolTipAny = billboard:FindFirstChild("EggToolTip", true)
	local eggToolTip: GuiObject? = nil
	if eggToolTipAny and eggToolTipAny:IsA("GuiObject") then
		eggToolTip = eggToolTipAny
		if not forceCompactSlots then
			normalizeEggToolTipContainer(eggToolTipAny)
		end
		for _, child in ipairs(eggToolTipAny:GetChildren()) do
			if child:IsA("GuiObject") and string.match(child.Name, "^PetRarity%d+$") then
				table.insert(slotCandidates, child)
			end
		end
		detectedPetRaritySlots = #slotCandidates > 0
	end

	for _, d in ipairs(billboard:GetDescendants()) do
		if #slotCandidates > 0 then
			break
		end
		if d:IsA("GuiObject") and d:GetAttribute("EggIconSlot") == true then
			table.insert(slotCandidates, d)
		end
	end
	if #slotCandidates == 0 then
		for _, d in ipairs(billboard:GetDescendants()) do
			if d:IsA("GuiObject") and (string.match(d.Name, "^Slot%d+$") or string.match(d.Name, "^PetRarity%d+$")) then
				table.insert(slotCandidates, d)
			end
		end
	end
	if #slotCandidates == 0 then
		local containerNames = {"Slots", "PetSlots", "Icons", "PetIcons"}
		for _, containerName in ipairs(containerNames) do
			local container = billboard:FindFirstChild(containerName, true)
			if container and container:IsA("GuiObject") then
				for _, child in ipairs(container:GetChildren()) do
					if child:IsA("GuiObject") then
						local hasImage = child:IsA("ImageLabel") or (child:FindFirstChildWhichIsA("ImageLabel", true) ~= nil)
						if hasImage then
							table.insert(slotCandidates, child)
						end
					end
				end
			end
			if #slotCandidates > 0 then
				break
			end
		end
	end
	if #slotCandidates == 0 then
		for _, d in ipairs(billboard:GetDescendants()) do
			if d:IsA("ImageLabel") then
				table.insert(slotCandidates, d)
			end
		end
	end

	local slots: {PreviewSlotBinding} = {}
	for i, slotRoot in ipairs(slotCandidates) do
		local slotBinding = buildSlotBinding(slotRoot, i)
		if slotBinding then
			table.insert(slots, slotBinding)
		end
	end

	table.sort(slots, function(a, b)
		return a.SortIndex < b.SortIndex
	end)
	local useCompactSlots = forceCompactSlots or detectedPetRaritySlots
	applyTemplateAutoScale(root, baseWidth, baseHeight, width, height, keepTemplateSize or useCompactSlots)
	normalizeTemplateSlotVisuals(slots)
	if useCompactSlots then
		compactTemplateSlots(eggToolTip, slots, width, height)
	end

	return {
		Gui = billboard,
		TitleLabel = title,
		PriceLabel = price,
		Slots = slots,
	}
end

local function ensurePreviewBinding(prompt: ProximityPrompt): PromptPreviewBinding
	local settings = EggCatalog.Settings or {}
	local minDistance = math.max(1, tonumber(settings.PreviewBillboardMinDistance) or 40)
	local distanceMul = math.max(0.1, tonumber(settings.PreviewBillboardDistanceMultiplier) or 2.5)
	local offsetY = tonumber(settings.PreviewBillboardOffsetY) or 3.7

	local existing = previewByPrompt[prompt]
	if existing then
		return existing
	end

	local source = getTemplateSource()
	local binding: PromptPreviewBinding? = nil
	if source then
		binding = createTemplateBillboardBinding(source)
	end
	if not binding then
		binding = createDefaultBillboardBinding()
	end

	local adornee = prompt.Parent
	if adornee and adornee:IsA("Attachment") then
		adornee = adornee.Parent
	end
	local promptAdornee: BasePart? = nil
	if adornee and adornee:IsA("BasePart") then
		promptAdornee = adornee
	end
	binding.Gui.Adornee = promptAdornee
	binding.Gui.MaxDistance = math.max(minDistance, prompt.MaxActivationDistance * distanceMul)
	binding.Gui.AlwaysOnTop = true
	binding.Gui.LightInfluence = 0
	if binding.Gui.StudsOffsetWorldSpace.Magnitude <= 0.001 then
		binding.Gui.StudsOffsetWorldSpace = Vector3.new(0, offsetY, 0)
	end
	binding.Gui.Enabled = false

	previewByPrompt[prompt] = binding
	return binding
end

local function getPreviewPetIconId(row: {[string]: any}, eggFallbackImageId: any): string
	local petName = tostring(row.PetName or "")
	if petName ~= "" then
		local petDef = select(1, PetCatalog.GetPetDefinition(petName))
		if petDef and petDef.IconId then
			return normalizeImageId(petDef.IconId)
		end
	end
	return normalizeImageId(eggFallbackImageId)
end

local function updatePreviewFromPrompt(prompt: ProximityPrompt)
	local eggIdAny = prompt:GetAttribute("EggId")
	if typeof(eggIdAny) ~= "string" or eggIdAny == "" then
		local binding = previewByPrompt[prompt]
		if binding then
			binding.Gui.Enabled = false
		end
		return
	end

	local eggDef, eggId = EggCatalog.GetEggDef(eggIdAny)
	if not eggDef or not eggId then
		local binding = previewByPrompt[prompt]
		if binding then
			binding.Gui.Enabled = false
		end
		return
	end

	local binding = ensurePreviewBinding(prompt)
	local currentAdornee = prompt.Parent
	if currentAdornee and currentAdornee:IsA("Attachment") then
		currentAdornee = currentAdornee.Parent
	end
	local activeAdornee: BasePart? = nil
	if currentAdornee and currentAdornee:IsA("BasePart") then
		activeAdornee = currentAdornee
	end
	binding.Gui.Adornee = activeAdornee

	local currencyName = tostring(eggDef.Price.Currency or "Coins")
	local cost = math.max(0, math.floor(tonumber(eggDef.Price.Amount) or 0))
	local coins, rubis = 0, 0
	local okWallet, c, r = pcall(function()
		return GetCurrencies:InvokeServer()
	end)
	if okWallet then
		coins = math.max(0, math.floor(tonumber(c) or 0))
		rubis = math.max(0, math.floor(tonumber(r) or 0))
	end

	local walletValue = (string.lower(currencyName) == "rubis") and rubis or coins
	local affordable = walletValue >= cost
	local costColor = affordable and Color3.fromRGB(170, 255, 190) or Color3.fromRGB(255, 150, 150)

	if binding.TitleLabel then
		binding.TitleLabel.Text = tostring(eggDef.DisplayName or eggId)
	end
	if binding.PriceLabel then
		binding.PriceLabel.Text = string.format("Cost: %d %s  |  You: %d", cost, currencyName, walletValue)
		binding.PriceLabel.TextColor3 = costColor
	end

	local slotCount = #binding.Slots
	if slotCount <= 0 then
		local fallback = tonumber(EggCatalog.Settings.PreviewSlotsFallback) or tonumber(EggCatalog.Settings.PreviewTopDrops) or 5
		slotCount = math.max(1, math.floor(fallback))
	end
	local previewDrops = EggCatalog.GetPreviewEntries(eggId, slotCount)

	for i, slot in ipairs(binding.Slots) do
		local row = previewDrops[i]
		if row then
			slot.Root.Visible = true
			setGuiObjectImage(slot.Icon, getPreviewPetIconId(row, eggDef.PreviewImageId), 0)

			if slot.ChanceLabel then
				local mode = string.lower(tostring(row.PowerMode or ""))
				local tag = ""
				if string.find(mode, "huge", 1, true) then
					tag = " H"
				elseif string.find(mode, "titanic", 1, true) then
					tag = " T"
				end
				setGuiObjectText(slot.ChanceLabel, fmtChance(tonumber(row.ChancePercent) or 0) .. tag)
				slot.ChanceLabel.Visible = true
			end
		else
			slot.Root.Visible = false
		end
	end

	binding.Gui.Enabled = true
end

local function hidePreviewIfPrompt(prompt: ProximityPrompt)
	local binding = previewByPrompt[prompt]
	if binding then
		binding.Gui.Enabled = false
		if not prompt:IsDescendantOf(game) then
			binding.Gui:Destroy()
			previewByPrompt[prompt] = nil
		end
	end
	if activePrompt == prompt then
		activePrompt = nil
	end
end

local function playHatch(payload: HatchPayload)
	local hatchCfg = payload.Hatch or EggCatalog.DefaultHatch
	local flashTime = math.max(0.03, tonumber(hatchCfg.FlashTime) or tonumber(EggCatalog.DefaultHatch.FlashTime) or 0.12)
	local holdResultTime = math.max(0.45, tonumber(hatchCfg.HoldResultTime) or tonumber(EggCatalog.DefaultHatch.HoldResultTime) or 1.15)
	local fadeOutTime = math.max(0.08, tonumber(hatchCfg.FadeOutTime) or tonumber(EggCatalog.DefaultHatch.FadeOutTime) or 0.2)
	local starStartY = tonumber(hatchCfg.StarStartY) or 1.26
	local starEntrySize = math.max(140, tonumber(hatchCfg.StarEntrySize) or 300)
	local starBurstSize = math.max(starEntrySize + 80, tonumber(hatchCfg.StarBurstSize) or 560)
	local starImageId = normalizeImageId(hatchCfg.StarImageId)

	local rarityColor = (typeof(payload.PetRarityColor) == "Color3") and payload.PetRarityColor or Color3.fromRGB(240, 240, 245)
	local variantName = tostring(payload.PetVariant or "Normal")
	local petLine = string.format("%s (%s)", tostring(payload.PetDisplayName or payload.PetName or "Pet"), variantName)
	if payload.PetPowerMode == "Huge" then
		petLine = petLine .. " [HUGE]"
	elseif payload.PetPowerMode == "Titanic" then
		petLine = petLine .. " [TITANIC]"
	end

	hatchOverlay.Visible = true
	hatchOverlay.BackgroundTransparency = 1
	hatchDim.Visible = true
	hatchDim.BackgroundTransparency = 1

	flash.Visible = false
	flash.BackgroundTransparency = 1

	hatchCard.Visible = false

	starRoot.Visible = true
	starRoot.Position = UDim2.fromScale(0.5, starStartY)
	starRoot.Size = UDim2.fromOffset(starEntrySize, starEntrySize)
	starRoot.Rotation = 0
	starScale.Scale = 1

	starMain.Image = starImageId
	starDetailFront.Image = starImageId
	starDetailBack.Image = starImageId
	starMain.ImageColor3 = rarityColor
	starMain.ImageTransparency = 0
	starDetailFront.ImageColor3 = rarityColor:Lerp(Color3.new(1, 1, 1), 0.35)
	starDetailFront.ImageTransparency = 0.34
	starDetailBack.ImageColor3 = rarityColor:Lerp(Color3.new(1, 1, 1), 0.55)
	starDetailBack.ImageTransparency = 0.56
	starDetailFront.Rotation = 0
	starDetailBack.Rotation = 0

	revealEggImage.Visible = true
	revealEggImage.Image = EggCatalog.NormalizeAssetId(payload.EggImageId)
	revealEggImage.ImageTransparency = 0.02

	revealPetImage.Visible = false
	revealPetImage.Image = EggCatalog.NormalizeAssetId(payload.PetIconId)
	revealPetImage.ImageTransparency = 1
	revealPetScale.Scale = 0.72

	revealName.Visible = true
	revealName.Text = petLine
	revealName.TextTransparency = 1
	revealRarity.Visible = true
	revealRarity.Text = string.upper(tostring(payload.PetRarity or "Common"))
	revealRarity.TextColor3 = rarityColor
	revealRarity.TextTransparency = 1

	tween(hatchDim, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.36,
	})

	local detailMotionActive = true
	local detailStart = os.clock()
	task.spawn(function()
		while detailMotionActive and hatchOverlay.Visible do
			RunService.RenderStepped:Wait()
			local t = os.clock() - detailStart
			starDetailFront.Rotation = t * 165
			starDetailBack.Rotation = -t * 118
			starScale.Scale = 1 + math.sin(t * 7.0) * 0.045
			starDetailFront.ImageTransparency = 0.30 + ((math.sin(t * 8.0) + 1) * 0.5) * 0.17
			starDetailBack.ImageTransparency = 0.50 + ((math.cos(t * 6.4) + 1) * 0.5) * 0.18
		end
	end)

	tween(starRoot, TweenInfo.new(0.44, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.5, 0.56),
	}).Completed:Wait()
	tween(starRoot, TweenInfo.new(0.10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.5, 0.49),
	}).Completed:Wait()
	tween(starRoot, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = UDim2.fromScale(0.5, 0.5),
	}).Completed:Wait()

	local wiggles = {
		{right = 10, left = -10, t = 0.065},
		{right = 13, left = -13, t = 0.07},
		{right = 22, left = -22, t = 0.085},
	}
	for _, w in ipairs(wiggles) do
		tween(starRoot, TweenInfo.new(w.t, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
			Rotation = w.right,
		}).Completed:Wait()
		tween(starRoot, TweenInfo.new(w.t, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
			Rotation = w.left,
		}).Completed:Wait()
	end

	flash.Visible = true
	flash.BackgroundTransparency = 1
	local flashIn = tween(flash, TweenInfo.new(flashTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.08,
	})
	local flashOut = TweenService:Create(flash, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
	})
	detailMotionActive = false
	tween(starRoot, TweenInfo.new(0.16, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(starBurstSize, starBurstSize),
		Rotation = 0,
	})
	tween(starMain, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1,
	})
	tween(starDetailFront, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1,
	})
	tween(starDetailBack, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1,
	})
	tween(revealEggImage, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1,
	})
	revealPetImage.Visible = true
	tween(revealPetImage, TweenInfo.new(0.24, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		ImageTransparency = 0,
	})
	tween(revealPetScale, TweenInfo.new(0.24, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Scale = 1,
	})
	tween(revealName, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0,
	})
	tween(revealRarity, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0,
	})
	flashIn.Completed:Wait()
	task.delay(0.055, function()
		flashOut:Play()
	end)

	task.wait(holdResultTime)

	tween(revealName, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		TextTransparency = 1,
	})
	tween(revealRarity, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		TextTransparency = 1,
	})
	tween(revealPetImage, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		ImageTransparency = 1,
	})
	local fadeDim = tween(hatchDim, TweenInfo.new(fadeOutTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	})
	fadeDim.Completed:Wait()

	resetHatchVisualState()
end

local function processQueue()
	if playingHatch then
		return
	end
	playingHatch = true
	while #resultQueue > 0 do
		local payload = table.remove(resultQueue, 1)
		if payload then
			local ok, err = pcall(playHatch, payload)
			if not ok then
				warn("[EggClient] playHatch failed:", tostring(err))
				resetHatchVisualState()
				showToast(false, "Falha na animacao do egg")
			end
		end
	end
	playingHatch = false
end

ProximityPromptService.PromptShown:Connect(function(prompt: ProximityPrompt)
	if not prompt or not prompt:IsDescendantOf(workspace) then
		return
	end
	local eggId = prompt:GetAttribute("EggId")
	if typeof(eggId) ~= "string" or eggId == "" then
		return
	end
	if activePrompt and activePrompt ~= prompt then
		hidePreviewIfPrompt(activePrompt)
	end
	activePrompt = prompt
	updatePreviewFromPrompt(prompt)
end)

ProximityPromptService.PromptHidden:Connect(function(prompt: ProximityPrompt)
	hidePreviewIfPrompt(prompt)
end)

EggOpenFeedback.OnClientEvent:Connect(function(ok: boolean, message: string)
	if ok == true then
		return
	end
	local text = tostring(message or "")
	if text == "" then
		text = "Falha ao abrir egg"
	end
	showToast(false, text)
end)

EggOpenResult.OnClientEvent:Connect(function(payload: any)
	if typeof(payload) ~= "table" then
		return
	end
	table.insert(resultQueue, payload :: HatchPayload)
	task.defer(processQueue)
end)
