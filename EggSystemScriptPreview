local function tween(obj: Instance, info: TweenInfo, goal: {[string]: any}): Tween
	local t = TweenService:Create(obj, info, goal)
	t:Play()
	return t
end

local function showToast(ok: boolean, message: string)
	local msg = tostring(message or "")
	if msg == "" then
		return
	end
	toastVersion += 1
	local version = toastVersion

	toast.Text = msg
	toast.TextColor3 = ok and Color3.fromRGB(120, 255, 155) or Color3.fromRGB(255, 110, 110)
	toast.BackgroundTransparency = 1
	toast.TextTransparency = 1
	toast.Visible = true

	tween(toast, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0,
	})
	task.delay(UI.ToastDuration, function()
		if version ~= toastVersion then
			return
		end
		local out = tween(toast, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			TextTransparency = 1,
		})
		out.Completed:Wait()
		if version ~= toastVersion then
			return
		end
		toast.Visible = false
	end)
end

local function fmtChance(n: number): string
	if n >= 10 then
		return string.format("%.1f%%", n)
	end
	if n >= 1 then
		return string.format("%.2f%%", n)
	end
	return string.format("%.3f%%", n)
end

local function normalizeImageId(raw: any): string
	if raw == nil then
		return "rbxasset://textures/ui/GuiImagePlaceholder.png"
	end
	local s = tostring(raw):gsub("%s+", "")
	if s == "" then
		return "rbxasset://textures/ui/GuiImagePlaceholder.png"
	end
	if string.sub(s, 1, #"rbxassetid://") == "rbxassetid://" then
		return s
	end
	if string.sub(s, 1, #"rbxasset://") == "rbxasset://" then
		return s
	end
	local n = tonumber(s)
	if n then
		return ("rbxassetid://%d"):format(n)
	end
	return EggCatalog.NormalizeAssetId(raw)
end

local function findFirstTextLabelByNames(root: Instance, names: {string}): TextLabel?
